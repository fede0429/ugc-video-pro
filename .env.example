# UGC Video Pro - Environment Variables
# ======================================
# Copy this file to .env and fill in your values.
# These values override config.yaml settings.
#
# NEVER commit .env to version control!
# Add ".env" to your .gitignore.


# ── Web Application ───────────────────────────────────────────
# General app secret (used for session signing, CSRF, etc.)
SECRET_KEY=your-random-secret-key-here

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-key-here


# ── Database (PostgreSQL) ─────────────────────────────────────
# Full async connection URL (used by SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://ugcvideo:your-db-password@db:5432/ugcvideo

# PostgreSQL service credentials (used by the db container)
POSTGRES_USER=ugcvideo
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=ugcvideo


# ── Default Admin Account ─────────────────────────────────────
# Created automatically on first startup — change immediately!
ADMIN_EMAIL=admin@ugcvideo.pro
ADMIN_PASSWORD=changeme123


# ── AI Model API Keys ─────────────────────────────────────────
# OpenAI — required for Sora models
OPENAI_API_KEY=sk-your-openai-api-key

# Google AI Studio — required for Gemini + Veo models
GOOGLE_API_KEY=your-google-api-key

# Seedance — required for Seedance models
SEEDANCE_API_KEY=your-seedance-api-key


# ── Logging ──────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
